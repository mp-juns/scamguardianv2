# ── 외부 API ──────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
SERPER_API_KEY=

# ── 어드민 (Auth.js v5 Google OIDC + 백엔드 forward 토큰) ────────
# 백엔드가 `/api/admin/*` 검증에 사용하는 단일 비밀.
# Next.js 가 Google 로그인 통과한 사용자에 한해 `X-Admin-Token` 헤더로 forward.
# 비워두면 어드민 접근 자체가 비활성화 (백엔드 401, 로그인 페이지 503).
SCAMGUARDIAN_ADMIN_TOKEN=

# 개발 모드 — true 로 두면 프런트/백엔드 어드민 인증 모두 bypass.
# 프로덕션 배포 시 반드시 false / 빈값으로.
ADMIN_AUTH_DISABLED=false

# 업로드 retention — `.scamguardian/uploads/**` mtime 기준 자동 삭제 (일).
# 0 으로 두면 비활성화. 백그라운드 sweep 주기는 UPLOAD_RETENTION_SWEEP_SEC (기본 24h).
UPLOAD_RETENTION_DAYS=30
UPLOAD_RETENTION_SWEEP_SEC=86400

# ── 카카오 오픈빌더 ────────────────────────
# 오픈빌더 > 스킬 > 스킬 서버 URL: https://<your-domain>/webhook/kakao
# (별도 시크릿 검증 없이 URL 자체를 비공개로 유지)

# ── 서버 ──────────────────────────────────
SCAMGUARDIAN_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3100,http://127.0.0.1:3100
SCAMGUARDIAN_DATABASE_URL=
SCAMGUARDIAN_SQLITE_PATH=.scamguardian/scamguardian.sqlite3
SCAMGUARDIAN_PERSIST_RUNS=false
SCAMGUARDIAN_RAG_TOP_K=3

# ── Ollama (선택, 로컬 LLM) ────────────────
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3.5:9b
