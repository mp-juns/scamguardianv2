# ── 외부 API ──────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
SERPER_API_KEY=

# ── 카카오 오픈빌더 ────────────────────────
# 오픈빌더 > 스킬 > 스킬 서버 URL: https://<your-domain>/webhook/kakao
# (별도 시크릿 검증 없이 URL 자체를 비공개로 유지)

# ── 서버 ──────────────────────────────────
SCAMGUARDIAN_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3100,http://127.0.0.1:3100
SCAMGUARDIAN_DATABASE_URL=
SCAMGUARDIAN_SQLITE_PATH=.scamguardian/scamguardian.sqlite3
SCAMGUARDIAN_PERSIST_RUNS=false
SCAMGUARDIAN_RAG_TOP_K=3

# ── Ollama (선택, 로컬 LLM) ────────────────
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3.5:9b
